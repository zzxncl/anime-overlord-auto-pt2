local HeroDropdown

local RarityDropdown = Tab:CreateDropdown({
    Name = "Select Rarity",
    Options = {"Mythical", "Secret", "Shiny"},
    CurrentOption = {"Mythical"},
    MultipleOptions = true,
    Flag = "RaritySelect",
    Callback = function(CurrentOption)
        local newOptions = {}

        if contains(CurrentOption, "Mythical") then
            for _, h in ipairs(mythicalHeroes) do table.insert(newOptions, h.display) end
        end
        if contains(CurrentOption, "Secret") then
            for _, h in ipairs(secretHeroes) do table.insert(newOptions, h.display) end
        end
        if contains(CurrentOption, "Shiny") then
            for _, h in ipairs(mythicalHeroes) do 
                if h.shiny then table.insert(newOptions, h.display .. " (Shiny)") end 
            end
            for _, h in ipairs(secretHeroes) do 
                if h.shiny then table.insert(newOptions, h.display .. " (Shiny)") end 
            end
        end

        table.sort(newOptions)

        if HeroDropdown then
            HeroDropdown:Refresh(newOptions)
            selectedHeroNames = {}
            selectedHeroes = {}
            HeroDropdown:Set({})
            
            local header = "Select Hero(s) to Summon Until"
            HeroDropdown.Name = header
            HeroDropdown:Refresh(HeroDropdown.Options)
        end
    end,
})

HeroDropdown = Tab:CreateDropdown({
    Name = "Select Hero(s) to Summon Until",
    Options = {"Goju"},
    CurrentOption = {},
    MultipleOptions = true,
    Flag = "HeroSelect",
    Callback = function(CurrentOption)
        selectedHeroes = {}
        selectedHeroNames = CurrentOption or {}

        for _, displayName in ipairs(selectedHeroNames) do
            local isShiny = string.find(displayName, "%(Shiny%)$") ~= nil
            local baseName = isShiny and string.gsub(displayName, " %([^)]+%)", "") or displayName

            local found = false
            for _, h in ipairs(mythicalHeroes) do
                if h.display == baseName then
                    if isShiny and h.shiny then table.insert(selectedHeroes, h.shiny)
                    else
                        table.insert(selectedHeroes, h.id)
                        if h.shiny then table.insert(selectedHeroes, h.shiny) end
                    end
                    found = true
                    break
                end
            end
            if not found then
                for _, h in ipairs(secretHeroes) do
                    if h.display == baseName then
                        if isShiny and h.shiny then table.insert(selectedHeroes, h.shiny)
                        else
                            table.insert(selectedHeroes, h.id)
                            if h.shiny then table.insert(selectedHeroes, h.shiny) end
                        end
                        break
                    end
                end
            end
        end

        local displayText = "None"
        if #selectedHeroNames > 0 then
            if #selectedHeroNames <= 3 then
                displayText = table.concat(selectedHeroNames, ", ")
            else
                displayText = table.concat({unpack(selectedHeroNames, 1, 3)}, ", ") .. " + " .. (#selectedHeroNames - 3) .. " more"
            end
        end
        if AutoHeroToggle then
            AutoHeroToggle:SetName("Auto Summon x10 Hero (" .. displayText .. ") - 0.7s Delay")
        end

        if HeroDropdown then
            local header = "Select Hero(s) to Summon Until"
            if #selectedHeroNames > 0 then
                if #selectedHeroNames <= 3 then
                    header = header .. " (" .. table.concat(selectedHeroNames, ", ") .. ")"
                else
                    header = header .. " (" .. table.concat({unpack(selectedHeroNames, 1, 3)}, ", ") .. " + " .. (#selectedHeroNames - 3) .. " more)"
                end
            end
            HeroDropdown.Name = header
            HeroDropdown:Refresh(HeroDropdown.Options)
        end
    end,
})

