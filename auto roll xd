local function contains(tbl, value)
    for _, v in ipairs(tbl) do if v == value then return true end end
    return false
end

-- ================== DETECTION (Crimson Queen Normal + Shiny) ==================
local crimsonTargets = {"crimsonqueen", "crimsonqueenshiny1"}

local function checkForHero(results, targets)
    if not results then return false end
    for _, hero in ipairs(results) do
        if type(hero) == "table" then
            local id = tostring(hero.id or hero.Id or ""):lower()
            for _, target in ipairs(targets) do
                if id == target:lower() then
                    print("🎉 " .. string.upper(target) .. " FOUND!")
                    task.wait(1.5)
                    if isHeroRunning then
                        isHeroRunning = false
                        print("Auto Hero stopped - Target hero found!")
                    end
                    return true
                end
            end
        end
    end
    return false
end

summonEvent.OnClientEvent:Connect(function(bufferData, extras)
    if not bufferData then return end

    pcall(function()
        local offset = 0
        local bufLen = buffer.len(bufferData)
        while offset < bufLen do
            local eventType = buffer.readu8(bufferData, offset)
            offset += 1
            if eventType == 0 then
                local count = buffer.readu16(bufferData, offset)
                offset += 2
                for i = 1, count do
                    local hasExtras = buffer.readu8(bufferData, offset) == 1
                    offset += 1
                    if hasExtras and extras and type(extras) == "table" then
                        if checkForHero(extras, crimsonTargets) then 
                            player:Kick("crimsonqueen found")
                            return 
                        end
                        if isHeroRunning and checkForHero(extras, selectedHeroes) then 
                            return 
                        end
                    end
                end
            else
                break
            end
        end
    end)

    if extras and type(extras) == "table" then
        if checkForHero(extras, crimsonTargets) then 
            player:Kick("crimsonqueen found")
            return 
        end
        if isHeroRunning and checkForHero(extras, selectedHeroes) then 
            return 
        end
    end
end)

-- Helper buffer
local function createSummonBuffer(bannerName)
    local bannerLen = #bannerName
    local buf = buffer.create(1 + 1 + 1 + 1 + 2 + bannerLen)
    buffer.writeu8(buf, 0, 0)
    buffer.writeu8(buf, 1, 1)
    buffer.writeu8(buf, 2, 10)
    buffer.writeu8(buf, 3, 1)
    buffer.writeu16(buf, 4, bannerLen)
    buffer.writestring(buf, 6, bannerName, bannerLen)
    return buf
end

-- ================== RARITY & HERO DROPDOWNS ==================
local HeroDropdown

local RarityDropdown = Tab:CreateDropdown({
    Name = "Select Rarity",
    Options = {"Mythical", "Secret", "Shiny"},
    CurrentOption = {"Mythical"},
    MultipleOptions = true,
    Flag = "RaritySelect",
    Callback = function(CurrentOption)
        local newOptions = {}

        if contains(CurrentOption, "Mythical") then
            for _, h in ipairs(mythicalHeroes) do table.insert(newOptions, h.display) end
        end
        if contains(CurrentOption, "Secret") then
            for _, h in ipairs(secretHeroes) do table.insert(newOptions, h.display) end
        end
        if contains(CurrentOption, "Shiny") then
            for _, h in ipairs(mythicalHeroes) do
                if h.shiny then table.insert(newOptions, h.display .. " (Shiny)") end
            end
            for _, h in ipairs(secretHeroes) do
                if h.shiny then table.insert(newOptions, h.display .. " (Shiny)") end
            end
        end

        table.sort(newOptions)

        if #newOptions > 0 and HeroDropdown then
            HeroDropdown:Refresh(newOptions)
            task.wait(0.1)                    -- Small delay helps Rayfield
            HeroDropdown:Set({newOptions[1]})
        end

        print("Rarity changed → " .. table.concat(CurrentOption, " + "))
    end,
})

HeroDropdown = Tab:CreateDropdown({
    Name = "Select Hero to Summon Until",
    Options = {"Bald Hero"},
    CurrentOption = {"Bald Hero"},
    MultipleOptions = false,
    Flag = "HeroSelect",
    Callback = function(CurrentOption)
        if #CurrentOption == 0 then return end

        local displayName = CurrentOption[1]
        selectedHeroes = {}

        -- Normal
        for _, h in ipairs(mythicalHeroes) do
            if h.display == displayName then
                table.insert(selectedHeroes, h.id)
                if h.shiny then table.insert(selectedHeroes, h.shiny) end
                break
            end
        end
        for _, h in ipairs(secretHeroes) do
            if h.display == displayName then
                table.insert(selectedHeroes, h.id)
                if h.shiny then table.insert(selectedHeroes, h.shiny) end
                break
            end
        end

        -- Shiny
        if string.find(displayName, "%(Shiny%)$") then
            local baseName = string.gsub(displayName, " %([^)]+%)", "")
            selectedHeroes = {}
            for _, h in ipairs(mythicalHeroes) do
                if h.display == baseName and h.shiny then
                    table.insert(selectedHeroes, h.shiny)
                    break
                end
            end
            for _, h in ipairs(secretHeroes) do
                if h.display == baseName and h.shiny then
                    table.insert(selectedHeroes, h.shiny)
                    break
                end
            end
        end

        print("Now targeting: " .. displayName)
    end,
})

