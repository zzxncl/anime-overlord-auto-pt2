local AutoSummonToggle = Tab:CreateToggle({
    Name = "Auto Summon x10 Crimson (14 times) - FAST",
    CurrentValue = false,
    Flag = "CrimsonAutoSummon",
    Callback = function(Value)
        isCrimsonRunning = Value
        crimsonSummonCount = 0
        if Value then
            print("⚡ Fast Auto Crimson started")
            task.spawn(function()
                while isCrimsonRunning and crimsonSummonCount < 14 do
                    local buf = createSummonBuffer("CRIMSON")
                    pcall(function() summonEvent:FireServer(buf, {}) end)
                    crimsonSummonCount += 1
                    print("Crimson x10 - Count: " .. crimsonSummonCount .. "/14")
                    task.wait(0.85 + math.random(0, 20)/100)  -- 0.85s to 1.05s
                end
                if crimsonSummonCount >= 14 then
                    isCrimsonRunning = false
                    AutoSummonToggle:Set(false)
                    Rayfield:Notify({Title = "Finished", Content = "14 x10 Crimson summons completed", Duration = 5})
                end
            end)
        else
            print("Auto Crimson stopped manually.")
        end
    end,
})

