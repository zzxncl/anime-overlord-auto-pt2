-- ================== RARITY & HERO DROPDOWNS ==================
local HeroDropdown

local RarityDropdown = Tab:CreateDropdown({
    Name = "Select Rarity",
    Options = {"Mythical", "Secret", "Shiny"},
    CurrentOption = {"Mythical"},
    MultipleOptions = true,
    Flag = "RaritySelect",
    Callback = function(CurrentOption)
        local newOptions = {}
        if contains(CurrentOption, "Mythical") then
            for _, h in ipairs(mythicalHeroes) do table.insert(newOptions, h.display) end
        end
        if contains(CurrentOption, "Secret") then
            for _, h in ipairs(secretHeroes) do table.insert(newOptions, h.display) end
        end
        if contains(CurrentOption, "Shiny") then
            for _, h in ipairs(mythicalHeroes) do
                if h.shiny then table.insert(newOptions, h.display .. " (Shiny)") end
            end
            for _, h in ipairs(secretHeroes) do
                if h.shiny then table.insert(newOptions, h.display .. " (Shiny)") end
            end
        end

        table.sort(newOptions)
        if #newOptions > 0 and HeroDropdown then
            HeroDropdown:Refresh(newOptions)
            task.wait(0.1)
            HeroDropdown:Set({newOptions[1]})
        end
    end,
})

HeroDropdown = Tab:CreateDropdown({
    Name = "Select Hero to Summon Until",
    Options = {"Bald Hero"},
    CurrentOption = {"Bald Hero"},
    MultipleOptions = false,
    Flag = "HeroSelect",
    Callback = function(CurrentOption)
        if #CurrentOption == 0 then return end
        local displayName = CurrentOption[1]
        selectedHeroes = {}

        for _, h in ipairs(mythicalHeroes) do
            if h.display == displayName then
                table.insert(selectedHeroes, h.id)
                if h.shiny then table.insert(selectedHeroes, h.shiny) end
                break
            end
        end
        for _, h in ipairs(secretHeroes) do
            if h.display == displayName then
                table.insert(selectedHeroes, h.id)
                if h.shiny then table.insert(selectedHeroes, h.shiny) end
                break
            end
        end

        if string.find(displayName, "%(Shiny%)$") then
            local base = string.gsub(displayName, " %([^)]+%)", "")
            selectedHeroes = {}
            for _, h in ipairs(mythicalHeroes) do
                if h.display == base and h.shiny then table.insert(selectedHeroes, h.shiny) break end
            end
            for _, h in ipairs(secretHeroes) do
                if h.display == base and h.shiny then table.insert(selectedHeroes, h.shiny) break end
            end
        end
        print("Now targeting: " .. displayName)
    end,
})

