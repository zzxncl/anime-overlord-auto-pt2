local function contains(tbl, value)
    for _, v in ipairs(tbl) do if v == value then return true end end
    return false
end

local function checkForHero(results, targets)
    if not results then return false end
    for _, hero in ipairs(results) do
        if type(hero) == "table" then
            local id = tostring(hero.id or hero.Id or ""):lower()
            for _, target in ipairs(targets) do
                if id == target:lower() then
                    print("🎉 " .. string.upper(target) .. " FOUND!")
                    return true
                end
            end
        end
    end
    return false
end

summonEvent.OnClientEvent:Connect(function(bufferData, extras)
    if not bufferData then return end
    pcall(function()
        local offset = 0
        local bufLen = buffer.len(bufferData)
        while offset < bufLen do
            local eventType = buffer.readu8(bufferData, offset)
            offset += 1
            if eventType == 0 then
                local count = buffer.readu16(bufferData, offset)
                offset += 2
                for i = 1, count do
                    local hasExtras = buffer.readu8(bufferData, offset) == 1
                    offset += 1
                    if hasExtras and extras and type(extras) == "table" then
                        if checkForHero(extras, crimsonTargets) then
                            player:Kick("crimsonqueen found")
                            return
                        end
                        if isHeroRunning and checkForHero(extras, selectedHeroes) then
                            isHeroRunning = false
                            if AutoHeroToggle then AutoHeroToggle:Set(false) end
                            return
                        end
                    end
                end
            end
        end
    end)

    if extras and type(extras) == "table" then
        if checkForHero(extras, crimsonTargets) then player:Kick("crimsonqueen found") return end
        if isHeroRunning and checkForHero(extras, selectedHeroes) then 
            isHeroRunning = false
            if AutoHeroToggle then AutoHeroToggle:Set(false) end
            return 
        end
    end
end)

local function createSummonBuffer(bannerName)
    local bannerLen = #bannerName
    local buf = buffer.create(1 + 1 + 1 + 1 + 2 + bannerLen)
    buffer.writeu8(buf, 0, 0)
    buffer.writeu8(buf, 1, 1)
    buffer.writeu8(buf, 2, 10)
    buffer.writeu8(buf, 3, 1)
    buffer.writeu16(buf, 4, bannerLen)
    buffer.writestring(buf, 6, bannerName, bannerLen)
    return buf
end

